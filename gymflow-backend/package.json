{
  "name": "gymflow-backend",
  "version": "1.0.0",
  "description": "GymFlow Backend API - Node.js + Express + PostgreSQL + Prisma",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
